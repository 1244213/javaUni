public class operazioni_esempio{

    public static void main(String[] args){

        int d = 531452;
        String sd = "" + d;

        System.out.println(sd);

        int len = sd.length();

        sd = "$" + sd.substring(0, len-3) + "," + sd.substring(len-3);
        System.out.println(sd);

        sd += "\t\tdollars\n\n\n";
        System.out.println(sd);

        sd = sd.trim();
        System.out.println(sd.toUpperCase());
    }
}